{
  "manifest_version": 3,
  "name": "QAForge Automation Readiness Analyzer",
  "version": "0.1.0",
  "description": "Analyze page automation readiness and inspect locator quality for stable test scripts.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "QAForge"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ]
}
